{
  "compilerOptions": {
    "target":            "ES2022",
    "module":            "CommonJS",
    "lib":               ["ES2022"],
    "outDir":            "./dist",
    "rootDir":           "./",
    "strict":            true,
    "esModuleInterop":   true,
    "resolveJsonModule": true,
    "skipLibCheck":      true,
    "moduleResolution":  "node16",
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist", "ui/.next"]
}
