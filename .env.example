# ─── AgenticFlow — Environment Configuration ─────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked with  ← CHANGE THIS
# 3. NEVER commit .env to git — it contains your private keys
# ──────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# Mainnet (use for hackathon submission)
ARC_API_URL=https://arc.taal.com
# Testnet (use for local testing — free sats from https://faucet.bitcoincloud.net)
# ARC_API_URL=https://arc-testnet.taal.com

ARC_API_KEY=your_arc_api_key_here             # ← CHANGE THIS (get at console.taal.com)

# ── On-chain identity ─────────────────────────────────────────────────────────
# Appears in every OP_RETURN — searchable on WhatsOnChain
AGENT_ID=AGFLOW26                             # ← Personalise if you want (max 16 chars)

# ── Skills Agent (MCP server / tool seller) ───────────────────────────────────
# Run  npm run generate-wallets  to generate all three wallets at once
SKILLS_AGENT_WIF=L...                         # ← CHANGE THIS
SKILLS_AGENT_ADDRESS=1...                     # ← CHANGE THIS
MCP_PORT=3100

# ── Client Agent (autonomous buyer / negotiator) ──────────────────────────────
CLIENT_AGENT_WIF=L...                         # ← CHANGE THIS
CLIENT_AGENT_ADDRESS=1...                     # ← CHANGE THIS
SKILLS_MCP_URL=http://localhost:3100
MAX_PRICE_SATS=500       # Reject tools priced above this
MIN_BALANCE_SATS=5000    # Pause if wallet drops below this

# ── TX Engine (high-frequency UTXO chain driver) ──────────────────────────────
ENGINE_AGENT_WIF=L...                         # ← CHANGE THIS
ENGINE_AGENT_ADDRESS=1...                     # ← CHANGE THIS
CHAIN_COUNT=20
TARGET_TPS=17.5
CHAIN_FUNDING_SATS=100000
MAX_CHAIN_DEPTH=5000
BROADCAST_CONCURRENCY=50

# ── Treasury UTXO ─────────────────────────────────────────────────────────────
# 1. Send >= 2,500,000 sats to ENGINE_AGENT_ADDRESS
# 2. Get the raw TX hex from WhatsOnChain or your wallet
# 3. Fill these three values
TREASURY_TX_HEX=0100000001...                 # ← CHANGE THIS (full raw TX hex)
TREASURY_VOUT=0                               # ← CHANGE THIS (output index)
TREASURY_SATS=2500000                         # ← CHANGE THIS (actual sats in that output)

# ── Debug ─────────────────────────────────────────────────────────────────────
LOG_EVENTS=0             # Set to 1 for verbose agent event logging
