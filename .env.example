# ─── AgenticFlow — Environment Configuration ─────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in every value marked with  ← CHANGE THIS
# 3. NEVER commit .env to git — it contains your private keys
# ──────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
# GorillaPool ARC (free, no API key required)
ARC_API_URL=https://arc.gorillapool.io
ARC_API_KEY=none

# Alternatives if GorillaPool is down:
# ARC_API_URL=https://arc.whatsonchain.com
# ARC_API_KEY=none

# TAAL (requires registration at https://platform.taal.com):
# ARC_API_URL=https://arc.taal.com
# ARC_API_KEY=mainnet_xxxxxxxxxxxxxxxxxxxxxxxx

# ── On-chain identity ─────────────────────────────────────────────────────────
# Appears in every OP_RETURN — searchable on WhatsOnChain
AGENT_ID=AGFLOW26

# ── Skills Agent (MCP server / tool seller) ───────────────────────────────────
# Run  npm run generate-wallets  to generate all three wallets at once
SKILLS_AGENT_WIF=L...                         # ← CHANGE THIS
SKILLS_AGENT_ADDRESS=1...                     # ← CHANGE THIS
MCP_PORT=3100

# ── Client Agent (autonomous buyer / negotiator) ──────────────────────────────
CLIENT_AGENT_WIF=L...                         # ← CHANGE THIS
CLIENT_AGENT_ADDRESS=1...                     # ← CHANGE THIS
SKILLS_MCP_URL=http://localhost:3100
MAX_PRICE_SATS=500
MIN_BALANCE_SATS=1000

# ── TX Engine (high-frequency UTXO chain driver) ──────────────────────────────
ENGINE_AGENT_WIF=L...                         # ← CHANGE THIS
ENGINE_AGENT_ADDRESS=1...                     # ← CHANGE THIS
CHAIN_COUNT=3
TARGET_TPS=1
CHAIN_FUNDING_SATS=10000
MAX_CHAIN_DEPTH=50
BROADCAST_CONCURRENCY=3

# ── Treasury UTXO ─────────────────────────────────────────────────────────────
# 1. Send >= 60,000 sats to ENGINE_AGENT_ADDRESS
# 2. Get the raw TX hex from WhatsOnChain → click TX → Raw Tx
# 3. Fill these three values
TREASURY_TX_HEX=0100000001...                 # ← CHANGE THIS
TREASURY_VOUT=0                               # ← CHANGE THIS
TREASURY_SATS=60000                           # ← CHANGE THIS

# ── Debug ─────────────────────────────────────────────────────────────────────
LOG_EVENTS=1
